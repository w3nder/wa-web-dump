{
  "manifest_version": 3,
  "name": "WA Web Dump (auth + app-state)",
  "version": "1.0.0",
  "description": "Abre o WhatsApp Web e exporta as credenciais de sessao (device + app-state) como JSON, sem precisar re-parear.",
  "permissions": ["scripting", "tabs", "downloads", "storage"],
  "host_permissions": ["https://web.whatsapp.com/*"],
  "optional_host_permissions": ["https://*/*", "http://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "WA Web Dump",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
